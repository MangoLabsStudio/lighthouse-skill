#!/usr/bin/env bash
set -euo pipefail

BASE="${LIGHTHOUSE_API_BASE:-https://service.lhdao.top/open-api/v1}"

die() { echo "error: $*" >&2; exit 1; }

is_nonneg_int() { [[ "$1" =~ ^[0-9]+$ ]]; }
is_pos_int()    { [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -gt 0 ]; }

usage() {
  cat <<'USAGE'
Usage:
  lighthouse balance
  lighthouse pricing
  lighthouse campaigns list [--status ACTIVE|PAUSED|ENDED|CLOSED] [--page N] [--page-size N]
  lighthouse campaigns get <id>
  lighthouse campaigns create-engagement \
     --url <tweet-url> \
     --action TYPE:TIER=N,TIER=N,... [--action TYPE:...] ... \
     [--expires-in-hours N] [--print-body]

Action spec:
  TYPE is one of LIKE|RT|COMMENT|FOLLOW|COMMENT_LIKE.
  TIER is one of A|B|C|D|E. Slot count must be a non-negative integer.
  Example: --action LIKE:A=5,B=10 --action RT:A=3
  Mutex: COMMENT_LIKE cannot be combined with LIKE or COMMENT.

Env:
  LIGHTHOUSE_API_KEY   required, must start with "lh_live_"
  LIGHTHOUSE_API_BASE  optional, default https://service.lhdao.top/open-api/v1

Requires: curl, jq.
USAGE
}

case "${1:-}" in ""|-h|--help) usage; exit 0;; esac

[ -n "${LIGHTHOUSE_API_KEY:-}" ] || die "LIGHTHOUSE_API_KEY env var is required"
[[ "$LIGHTHOUSE_API_KEY" == lh_live_* ]] || die "LIGHTHOUSE_API_KEY must start with lh_live_"

command -v curl >/dev/null || die "curl not found"
command -v jq   >/dev/null || die "jq not found"

req() {
  local method="$1" path="$2" body="${3:-}"
  local args=(-sS -X "$method" -H "X-API-Key: $LIGHTHOUSE_API_KEY" -H "Content-Type: application/json")
  [ -n "$body" ] && args+=(--data "$body")
  local tmp http
  tmp=$(mktemp) || die "mktemp failed"
  http=$(curl "${args[@]}" -o "$tmp" -w '%{http_code}' "$BASE$path") || { rm -f "$tmp"; die "curl failed"; }
  cat "$tmp"; rm -f "$tmp"
  if [ "$http" -lt 200 ] || [ "$http" -ge 300 ]; then
    echo "HTTP $http" >&2
    return 1
  fi
}

parse_action() {
  # Input: $1 like "LIKE:A=5,B=10"
  # Appends one action object to global actions_json.
  local spec="$1"
  [[ "$spec" == *:* ]] || die "invalid --action (expected TYPE:TIER=N,...): $spec"
  local type="${spec%%:*}"
  local slots="${spec#*:}"
  case "$type" in
    LIKE|RT|COMMENT|FOLLOW|COMMENT_LIKE) ;;
    *) die "invalid action type: $type (expected LIKE|RT|COMMENT|FOLLOW|COMMENT_LIKE)";;
  esac
  [ -n "$slots" ] || die "--action $type: empty tier list"

  local slots_obj='{}'
  local action_total=0
  IFS=',' read -ra pairs <<<"$slots"
  for p in "${pairs[@]}"; do
    [ -n "$p" ] || die "--action $type: empty tier pair"
    [[ "$p" == *=* ]] || die "--action $type: invalid pair '$p' (expected TIER=N)"
    local k="${p%%=*}" v="${p#*=}"
    case "$k" in
      A|B|C|D|E) ;;
      *) die "invalid tier: $k (expected A|B|C|D|E; S is not allowed)";;
    esac
    is_nonneg_int "$v" || die "slot count for $type:$k must be non-negative integer, got: $v"
    # Duplicate tiers within one action: later value overrides (jq + : object merge).
    slots_obj=$(jq -c --arg k "$k" --argjson v "$v" '. + {($k): $v}' <<<"$slots_obj")
    action_total=$((action_total + v))
  done

  total_slots=$((total_slots + action_total))
  case "$type" in
    LIKE|COMMENT) has_like_or_comment=1;;
    COMMENT_LIKE) has_comment_like=1;;
  esac

  local one
  one=$(jq -nc --arg t "$type" --argjson slots "$slots_obj" '{actionType:$t, tierSlots:$slots}')
  actions_json=$(jq -c --argjson a "$one" '. + [$a]' <<<"$actions_json")
}

cmd="$1"; shift
case "$cmd" in
  balance)
    req GET /balance | jq .
    ;;
  pricing)
    req GET /pricing | jq .
    ;;
  campaigns)
    sub="${1:-}"; shift || true
    [ -n "$sub" ] || die "usage: lighthouse campaigns <list|get|create-engagement>"
    case "$sub" in
      list)
        qs=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --status)
              case "$2" in ACTIVE|PAUSED|ENDED|CLOSED) ;; *) die "--status must be ACTIVE/PAUSED/ENDED/CLOSED";; esac
              qs+="${qs:+&}status=$2"; shift 2;;
            --page)
              is_nonneg_int "$2" || die "--page must be a non-negative integer, got: $2"
              qs+="${qs:+&}page=$2"; shift 2;;
            --page-size)
              is_nonneg_int "$2" || die "--page-size must be a non-negative integer, got: $2"
              qs+="${qs:+&}pageSize=$2"; shift 2;;
            *) die "unknown arg: $1";;
          esac
        done
        req GET "/campaigns${qs:+?$qs}" | jq .
        ;;
      get)
        id="${1:?id required}"
        req GET "/campaigns/$id" | jq .
        ;;
      create-engagement)
        url="" expires="" print_body=0
        actions_json='[]'
        total_slots=0
        has_like_or_comment=0
        has_comment_like=0
        while [ $# -gt 0 ]; do
          case "$1" in
            --url) url="$2"; shift 2;;
            --action)
              [ $# -ge 2 ] || die "--action requires a value"
              parse_action "$2"; shift 2;;
            --expires-in-hours)
              is_pos_int "$2" || die "--expires-in-hours must be a positive integer, got: $2"
              expires="$2"; shift 2;;
            --print-body) print_body=1; shift;;
            *) die "unknown arg: $1";;
          esac
        done
        [ -n "$url" ] || die "--url is required"
        [ "$(jq 'length' <<<"$actions_json")" -gt 0 ] || die "at least one --action is required"
        [ "$total_slots" -gt 0 ] || die "total slots must be > 0 across all --action"
        if [ "$has_comment_like" -eq 1 ] && [ "$has_like_or_comment" -eq 1 ]; then
          die "COMMENT_LIKE cannot be combined with LIKE or COMMENT"
        fi
        body=$(jq -nc \
          --arg url "$url" --argjson actions "$actions_json" --arg expires "$expires" '
          {targetUrl:$url, actions:$actions}
          + (if $expires == "" then {} else {expiresInHours:($expires|tonumber)} end)')
        if [ "$print_body" -eq 1 ]; then
          echo "$body"
          exit 0
        fi
        req POST /campaigns/engagement "$body" | jq .
        ;;
      *) die "unknown campaigns subcommand: $sub";;
    esac
    ;;
  *) die "unknown command: $cmd";;
esac
